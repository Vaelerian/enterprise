# Copy this file to .env.local and fill in the values.

# Database
# For local dev with docker compose: postgresql://postgres:postgres@localhost:5432/enterprise?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/enterprise?schema=public"

# NextAuth
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Claude API (required for AI generation)
ANTHROPIC_API_KEY=""

# Public app URL (exposed to the browser, should match NEXTAUTH_URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Azure Graph API (required for registration, invites, password reset emails)
# The app registration needs Mail.Send permission with admin consent.
# Leave blank for UI-only local testing - email flows will throw if called.
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
AZURE_SENDER_EMAIL=""
